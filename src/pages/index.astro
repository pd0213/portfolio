---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const works3d = await getCollection('3d').catch(() => []);
const works2d = await getCollection('2d').catch(() => []);
---
<Layout>
  <main class="min-h-screen font-sans" style="background-color: #fce8ee;">
    <div class="fixed left-0 top-0 h-full" style="width: 32px; background-color: #7dd3e8; z-index: 5;"></div>
    <div style="padding-left: 32px;">
      <header class="bg-white border-b py-6 px-8" style="border-color: #fbc8d8; z-index: 10; position: relative;">
        <div class="max-w-5xl mx-auto flex items-center justify-between">
          <div class="text-center flex-1">
            <h1 class="text-3xl font-bold tracking-[0.3em]" style="color: #2d3e6e;">PORTFOLIO</h1>
            <p class="text-sm mt-1 tracking-widest" style="color: #7dd3e8;">works by yan</p>
          </div>
          <div class="flex gap-4 items-center">
            <a href="https://x.com/McDonalds" target="_blank" rel="noopener" style="color: #2d3e6e;" class="hover:opacity-60 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="https://booth.pm" target="_blank" rel="noopener" style="color: #2d3e6e;" class="hover:opacity-60 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 75 75" fill="currentColor">
                <path d="M10 10 h30 a15 15 0 0 1 0 30 h-30 z"/>
                <path d="M10 40 h35 a17.5 17.5 0 0 1 0 35 h-35 z"/>
              </svg>
            </a>
          </div>
        </div>
      </header>
      <div class="flex justify-center mt-10 gap-4">
        <button id="tab-3d" onclick="switchTab('3d')" class="px-8 py-2 rounded-full border-2 font-bold tracking-wider transition-all duration-200 bg-white" style="border-color: #fbacc8; color: #2d3e6e;">
          3D
        </button>
        <button id="tab-2d" onclick="switchTab('2d')" class="px-8 py-2 rounded-full border-2 font-bold tracking-wider transition-all duration-200 bg-white" style="border-color: #7dd3e8; color: #2d3e6e;">
          2D
        </button>
      </div>
      <section id="gallery-3d" class="max-w-5xl mx-auto px-6 py-10">
        {works3d.length === 0 ? (
          <p class="text-center py-20" style="color: #fbacc8;">まだ作品がありません</p>
        ) : (
          <div class="grid grid-cols-3 gap-6">
            {works3d.map((work) => (
              <div class="flex flex-col gap-2">
                <div class="relative group overflow-hidden rounded-xl cursor-pointer modal-trigger" data-type="video" data-src={work.data.video} data-title={work.data.title} data-desc={work.data.description} style="aspect-ratio: 2/3; background-color: #fce8ee;">
                  <video src={work.data.video} autoplay loop muted playsinline class="w-full h-full object-cover" />
                  <div class="absolute inset-0 flex flex-col justify-end p-3 opacity-0 group-hover:opacity-100 transition-all duration-300" style="background: rgba(0,0,0,0.45);">
                    <p class="font-bold text-sm text-white">{work.data.title}</p>
                    <p class="text-xs mt-1 line-clamp-2 text-white opacity-80">{work.data.description}</p>
                  </div>
                </div>
                {work.data.images && work.data.images.length > 0 && (
                  <div class="grid grid-cols-3 gap-1">
                    {work.data.images.map((img, i) => (
                      <div class="relative group overflow-hidden rounded-lg cursor-pointer modal-trigger" data-type="image" data-src={img} data-title={work.data.title} data-desc="" style="aspect-ratio: 1/1; background-color: #fce8ee;">
                        <img src={img} alt={`wireframe-${i}`} class="w-full h-full object-cover" />
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-300" style="background: rgba(0,0,0,0.35);" />
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </section>
      <section id="gallery-2d" class="max-w-5xl mx-auto px-6 py-10 hidden">
        {works2d.length === 0 ? (
          <p class="text-center py-20" style="color: #7dd3e8;">まだ作品がありません</p>
        ) : (
          <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
            {works2d.map((work) => (
              <div class="relative group overflow-hidden rounded-xl break-inside-avoid cursor-pointer modal-trigger" data-type="image" data-src={work.data.image} data-title={work.data.title} data-desc={work.data.description}>
                <img src={work.data.image} alt={work.data.title} class="w-full object-cover" />
                <div class="absolute inset-0 flex flex-col justify-end p-3 opacity-0 group-hover:opacity-100 transition-all duration-300" style="background: rgba(0,0,0,0.45);">
                  <p class="font-bold text-sm text-white">{work.data.title}</p>
                  <p class="text-xs mt-1 line-clamp-2 text-white opacity-80">{work.data.description}</p>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    </div>
    <div id="modal" class="fixed inset-0 hidden items-center justify-center z-50 p-8" style="background: rgba(0,0,0,0.75);">
      <button onclick="closeModal()" class="absolute top-6 right-8 text-white text-4xl font-light leading-none z-10">&times;</button>
      <div id="modal-content" class="max-h-full" style="max-width: 480px; width: 100%;"></div>
    </div>
  </main>
</Layout>
<script is:inline>
  function switchTab(tab) {
    var gallery3d = document.getElementById('gallery-3d');
    var gallery2d = document.getElementById('gallery-2d');
    var tab3d = document.getElementById('tab-3d');
    var tab2d = document.getElementById('tab-2d');
    if (tab === '3d') {
      gallery3d.classList.remove('hidden');
      gallery2d.classList.add('hidden');
      tab3d.style.backgroundColor = '#fbacc8';
      tab3d.style.color = '#fff';
      tab2d.style.backgroundColor = '#fff';
      tab2d.style.color = '#2d3e6e';
    } else {
      gallery2d.classList.remove('hidden');
      gallery3d.classList.add('hidden');
      tab2d.style.backgroundColor = '#7dd3e8';
      tab2d.style.color = '#fff';
      tab3d.style.backgroundColor = '#fff';
      tab3d.style.color = '#2d3e6e';
    }
  }
  switchTab('3d');
  document.querySelectorAll('.modal-trigger').forEach(function(el) {
    el.addEventListener('click', function() {
      var type = el.dataset.type;
      var src = el.dataset.src;
      var modal = document.getElementById('modal');
      var content = document.getElementById('modal-content');
      if (type === 'video') {
        content.innerHTML = '<video src="' + src + '" autoplay loop muted playsinline style="width:100%; max-height: calc(100vh - 4rem); object-fit: contain; border-radius: 12px;"></video>';
      } else {
        content.innerHTML = '<img src="' + src + '" style="width:100%; max-height: calc(100vh - 4rem); object-fit: contain; border-radius: 12px;" />';
      }
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });
  });
  function closeModal() {
    var modal = document.getElementById('modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.getElementById('modal-content').innerHTML = '';
  }
  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>
